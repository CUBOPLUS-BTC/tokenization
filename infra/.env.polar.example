# Polar LND connection for local Lightning integration tests.
#
# In Polar, open your backend node, copy its gRPC host port and TLS/macaroon
# file locations, then create infra/.env.polar with these values.
#
# From a Docker container, localhost points at the container itself. Use
# host.docker.internal to reach Polar's host-published gRPC port.
POLAR_LND_GRPC_HOST=host.docker.internal
POLAR_LND_GRPC_PORT=10001

# Use forward slashes on Windows paths so Docker Compose parses them cleanly.
POLAR_LND_TLS_CERT_FILE=C:/Users/DELL/path/to/polar/node/tls.cert
POLAR_LND_MACAROON_FILE=C:/Users/DELL/path/to/polar/node/data/chain/bitcoin/regtest/admin.macaroon

# Polar/LND certificates are commonly valid for localhost, while the container
# connects through host.docker.internal. Override only the TLS verification name.
POLAR_LND_TLS_SERVER_NAME=localhost
