# Local development profile
ENV_PROFILE=local

# Note: defaults below are tuned for Docker Compose service discovery.
# If you run services directly on host, override hosts with localhost.

# Service routing
# Gateway: allowed Origin header for browser clients (CORS)
# Comma-separated list (gateway maps each Origin exactly)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Gateway is the single source of truth for CORS. Uncomment to override
# the defaults compiled into the gateway image.
# CORS_ALLOWED_METHODS=GET, POST, PUT, PATCH, DELETE, OPTIONS
# CORS_ALLOWED_HEADERS=Authorization, Content-Type, X-Requested-With, Accept, Origin, X-Request-ID, X-Correlation-ID, X-API-Key, X-2FA-Code, X-Idempotency-Key
# CORS_EXPOSE_HEADERS=X-Request-ID
# CORS_MAX_AGE=86400
# CORS_ALLOW_CREDENTIALS=true

WALLET_SERVICE_URL=http://wallet:8001
TOKENIZATION_SERVICE_URL=http://tokenization:8002
MARKETPLACE_SERVICE_URL=http://marketplace:8003

NOSTR_SERVICE_URL=http://nostr:8005
AUTH_SERVICE_URL=http://auth:8000

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tokenization
POSTGRES_USER=local_user
POSTGRES_PASSWORD=local_password
# Optional secure alternative:
# POSTGRES_PASSWORD_FILE=secrets/postgres_password.txt
DATABASE_URL=postgresql+pg8000://local_user:local_password@postgres:5432/tokenization

# Redis
REDIS_URL=redis://redis:6379/0

# Bitcoin RPC
BITCOIN_RPC_HOST=bitcoind
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=local_rpc
BITCOIN_RPC_PASSWORD=local_rpc_password
BITCOIN_NETWORK=regtest
BITCOIN_RPC_REQUIRED=true

# LND gRPC
LND_GRPC_HOST=lnd
LND_GRPC_PORT=10009
LND_MACAROON_PATH=/run/secrets/lnd/data/chain/bitcoin/regtest/admin.macaroon
LND_TLS_CERT_PATH=/run/secrets/lnd/tls.cert
LND_GRPC_REQUIRED=true

# Elements / Liquid RPC
ELEMENTS_RPC_HOST=elementsd
ELEMENTS_RPC_PORT=7041
ELEMENTS_RPC_USER=user
ELEMENTS_RPC_PASSWORD=pass
ELEMENTS_NETWORK=elementsregtest
ELEMENTS_WALLET_NAME=platform
ELEMENTS_RPC_REQUIRED=true

# Nostr
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol
# NOSTR_PRIVATE_KEY=

# Auth
JWT_SECRET=local_jwt_secret
# JWT_SECRET_FILE=secrets/jwt_secret.txt
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
TOTP_ISSUER=RWAPlatform

# Initial admin created by manual db bootstrap
INITIAL_ADMIN_EMAIL=admin@local.test
INITIAL_ADMIN_PASSWORD=LocalAdmin123!
INITIAL_ADMIN_DISPLAY_NAME=Local Platform Admin

# AI
OPENAI_API_KEY=
# OPENAI_API_KEY_FILE=secrets/openai_api_key.txt

# Runtime
LOG_LEVEL=DEBUG
MARKETPLACE_ESCROW_WATCH_INTERVAL_SECONDS=30
MARKETPLACE_ESCROW_FEE_RESERVE_SAT=5000

# Wallet Security (dev-only; replace in staging/beta/production)
# 32-byte hex key for seed encryption (generate with: openssl rand -hex 32)
WALLET_ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
# WALLET_ENCRYPTION_KEY_FILE=secrets/wallet_encryption_key.txt

# Alerting
# ALERT_WEBHOOK_URL=http://localhost:9000/hooks/local
