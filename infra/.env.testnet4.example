# Testnet4 profile
ENV_PROFILE=staging

# Public ingress
APP_PUBLIC_BASE_URL=https://testnet4.example.com

# Service routing
# Gateway: allowed Origin for browser clients (CORS); must match your SPA URL exactly
CORS_ALLOWED_ORIGINS=https://app.yourfrontend.com

WALLET_SERVICE_URL=http://wallet:8001
TOKENIZATION_SERVICE_URL=http://tokenization:8002
MARKETPLACE_SERVICE_URL=http://marketplace:8003
NOSTR_SERVICE_URL=http://nostr:8005

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tokenization_testnet4
POSTGRES_USER=testnet4_user
POSTGRES_PASSWORD=testnet4_password
DATABASE_URL=postgresql+pg8000://testnet4_user:testnet4_password@postgres:5432/tokenization_testnet4

# Redis
REDIS_URL=redis://redis:6379/0

# Bitcoin Core / testnet4
BITCOIN_RPC_HOST=bitcoind
BITCOIN_RPC_PORT=48332
BITCOIN_RPC_USER=testnet4_rpc
BITCOIN_RPC_PASSWORD=testnet4_rpc_password
BITCOIN_NETWORK=testnet4
BITCOIN_RPC_REQUIRED=true

# LND
LND_GRPC_HOST=lnd
LND_GRPC_PORT=10009
LND_MACAROON_PATH=/run/secrets/lnd/data/chain/bitcoin/testnet/admin.macaroon
LND_TLS_CERT_PATH=/run/secrets/lnd/tls.cert
LND_GRPC_REQUIRED=true

# Elements / Liquid testnet
ELEMENTS_RPC_HOST=elementsd
ELEMENTS_RPC_PORT=7041
ELEMENTS_RPC_USER=user
ELEMENTS_RPC_PASSWORD=pass
ELEMENTS_NETWORK=liquidtestnet
ELEMENTS_WALLET_NAME=platform
ELEMENTS_RPC_REQUIRED=true

# Nostr
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# Auth
JWT_SECRET=testnet4_jwt_secret_change_me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
TOTP_ISSUER=RWAPlatform-Testnet4

# Initial admin created by manual db bootstrap
INITIAL_ADMIN_EMAIL=admin@testnet4.example.com
INITIAL_ADMIN_PASSWORD=Testnet4Admin123!
INITIAL_ADMIN_DISPLAY_NAME=Testnet4 Platform Admin

# AI
OPENAI_API_KEY=

# Wallet Security
WALLET_ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Alerting
# ALERT_WEBHOOK_URL=https://hooks.example.com/testnet4

# Runtime
LOG_LEVEL=INFO
MARKETPLACE_ESCROW_WATCH_INTERVAL_SECONDS=60
MARKETPLACE_ESCROW_FEE_RESERVE_SAT=5000
