# ============================================
# RWA Tokenization Platform — Environment Vars
# ============================================
# Copy this file to .env and fill in values.
# NEVER commit your .env file.

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tokenization
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+pg8000://user:pass@localhost:5432/tokenization

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Bitcoin Core ---
BITCOIN_RPC_HOST=localhost
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_NETWORK=regtest

# --- LND ---
LND_GRPC_HOST=localhost
LND_GRPC_PORT=10009
LND_MACAROON_PATH=
LND_TLS_CERT_PATH=

# --- Elements / Liquid ---
ELEMENTS_RPC_HOST=localhost
ELEMENTS_RPC_PORT=7041
ELEMENTS_RPC_USER=
ELEMENTS_RPC_PASSWORD=
ELEMENTS_NETWORK=elementsregtest
ELEMENTS_WALLET_NAME=

# --- Nostr ---
# Comma-separated list of relay URLs
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# --- JWT / Auth ---
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
TOTP_ISSUER=RWAPlatform

# --- AI / ML ---
OPENAI_API_KEY=

# --- Wallet Security ---
WALLET_ENCRYPTION_KEY=

# --- Alerting ---
ALERT_WEBHOOK_URL=

# --- KYC ---
# Trade threshold in sats above which KYC verification is required (0 = disabled)
KYC_TRADE_THRESHOLD_SAT=0

# --- Runtime ---
LOG_LEVEL=DEBUG
