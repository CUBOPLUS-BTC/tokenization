# ============================================
# RWA Tokenization Platform — Environment Vars
# ============================================
# Copy this file to .env and fill in values.
# NEVER commit your .env file.

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tokenization
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+pg8000://user:pass@localhost:5432/tokenization

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Bitcoin Core ---
BITCOIN_RPC_HOST=localhost
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_NETWORK=regtest
BITCOIN_RPC_REQUIRED=true

# --- LND ---
LND_GRPC_HOST=localhost
LND_GRPC_PORT=10009
LND_MACAROON_PATH=
LND_TLS_CERT_PATH=
LND_GRPC_REQUIRED=

# --- Elements / Liquid ---
ELEMENTS_RPC_HOST=localhost
ELEMENTS_RPC_PORT=7041
ELEMENTS_RPC_USER=
ELEMENTS_RPC_PASSWORD=
ELEMENTS_NETWORK=elementsregtest
ELEMENTS_WALLET_NAME=
ELEMENTS_RPC_REQUIRED=

# --- Nostr ---
# Comma-separated list of relay URLs
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# --- JWT / Auth ---
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
TOTP_ISSUER=RWAPlatform

# --- AI / ML ---
OPENAI_API_KEY=

# --- Wallet Security ---
WALLET_ENCRYPTION_KEY=

# --- Alerting ---
ALERT_WEBHOOK_URL=

# --- KYC ---
# Trade threshold in sats above which KYC verification is required (0 = disabled)
KYC_TRADE_THRESHOLD_SAT=0
# Optional Ory Kratos admin integration used to mirror KYC state onto identities.
# Kratos is used here as an identity/KYC-state system of record, not as a
# document-verification provider.
# ORY_KRATOS_ADMIN_URL=http://localhost:4434
# ORY_KRATOS_ADMIN_TOKEN=
# ORY_KRATOS_IDENTITY_SCHEMA_ID=default

# --- CORS ---
# Comma-separated list of allowed browser Origin values. Consumed by the
# gateway (nginx) and, when set, by the in-process FastAPI CORSMiddleware.
# Example: http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Gateway is the single source of truth for CORS. Uncomment to override
# the defaults compiled into the gateway image.
# CORS_ALLOWED_METHODS=GET, POST, PUT, PATCH, DELETE, OPTIONS
# CORS_ALLOWED_HEADERS=Authorization, Content-Type, X-Requested-With, Accept, Origin, X-Request-ID, X-Correlation-ID, X-API-Key, X-2FA-Code, X-Idempotency-Key
# CORS_EXPOSE_HEADERS=X-Request-ID
# CORS_MAX_AGE=86400
# CORS_ALLOW_CREDENTIALS=true

# --- Runtime ---
LOG_LEVEL=DEBUG
